# Copy to .env.local and fill in. All values are optional —
# features degrade gracefully (hidden) when their vars are unset.

# Upstash Redis — blog view counter (https://console.upstash.com)
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=

# Giscus comments — generate at https://giscus.app
NEXT_PUBLIC_GISCUS_REPO=metehanulusoy/metehanulusoy.dev
NEXT_PUBLIC_GISCUS_REPO_ID=
NEXT_PUBLIC_GISCUS_CATEGORY=Comments
NEXT_PUBLIC_GISCUS_CATEGORY_ID=

# Site
NEXT_PUBLIC_SITE_URL=https://metehanulusoy.dev
